# ============================================================
# Solar WiFi Weather Station – API Verzeichnisschutz
# ============================================================

# Verzeichnislisting deaktivieren
Options -Indexes

# Hilfsdateien vor Direktzugriff schützen
<Files "auth.php">
	Order allow,deny
	Deny from all
</Files>
<Files "db.php">
	Order allow,deny
	Deny from all
</Files>
