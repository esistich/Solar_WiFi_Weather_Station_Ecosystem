# ============================================================
# Solar WiFi Weather Station – API Verzeichnisschutz + Routing
# ============================================================

Options -Indexes

# ---- v1 URL-Rewriting ----
RewriteEngine On
RewriteBase /sws/api

# Authorization-Header an PHP weitergeben (CGI/FastCGI auf Shared Hosting)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# /v1/<route> → v1/index.php (außer echte Dateien)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^v1/(.*)$ v1/index.php [QSA,L]

# ---- Zugriffsschutz ----

# auth.php und db.php vor Direktzugriff schützen
<FilesMatch "^(auth|db)\.php$">
	Require all denied
</FilesMatch>

# Service-Account-JSON vor Direktzugriff schützen
<FilesMatch "\.json$">
	Require all denied
</FilesMatch>
