# ============================================================
# Solar WiFi Weather Station – API Verzeichnisschutz
# ============================================================

# Verzeichnislisting deaktivieren
Options -Indexes

# lib/ komplett vor Direktzugriff schützen
<IfModule mod_authz_core.c>
	<Directory "lib">
		Require all denied
	</Directory>
</IfModule>
# Fallback für ältere Apache-Versionen
<FilesMatch "^(auth|db)\.php$">
	Order allow,deny
	Deny from all
</FilesMatch>

# Service-Account-JSON vor Direktzugriff schützen
<FilesMatch "firebase_service_account\.json$">
	Require all denied
</FilesMatch>
