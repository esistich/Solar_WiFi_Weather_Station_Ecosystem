// DIESE DATEI NICHT MIT ECHTEN WERTEN COMMITTEN!
//
// firebase_options.dart wird lokal generiert mit:
//   flutterfire configure
//
// Voraussetzungen:
//   dart pub global activate flutterfire_cli
//   Einmalig: Firebase-Projekt unter https://console.firebase.google.com anlegen
//
// Die echte firebase_options.dart ist in .gitignore eingetragen und bleibt lokal.

import 'package:firebase_core/firebase_core.dart' show FirebaseOptions;
import 'package:flutter/foundation.dart'
	show defaultTargetPlatform, kIsWeb, TargetPlatform;

class DefaultFirebaseOptions {
  static FirebaseOptions get currentPlatform {
	if (kIsWeb) return web;
	switch (defaultTargetPlatform) {
	  case TargetPlatform.android:
		return android;
	  case TargetPlatform.iOS:
		return ios;
	  default:
		throw UnsupportedError(
		  'DefaultFirebaseOptions sind fuer diese Plattform nicht konfiguriert.',
		);
	}
  }

  // Platzhalter – echte Werte per "flutterfire configure" generieren
  static const FirebaseOptions android = FirebaseOptions(
	apiKey: 'DEIN_ANDROID_API_KEY',
	appId: 'DEINE_APP_ID',
	messagingSenderId: 'DEINE_SENDER_ID',
	projectId: 'DEIN_PROJECT_ID',
	storageBucket: 'DEIN_PROJECT_ID.appspot.com',
  );

  static const FirebaseOptions web = FirebaseOptions(
	apiKey: 'DEIN_WEB_API_KEY',
	appId: 'DEINE_WEB_APP_ID',
	messagingSenderId: 'DEINE_SENDER_ID',
	projectId: 'DEIN_PROJECT_ID',
	storageBucket: 'DEIN_PROJECT_ID.appspot.com',
  );

  static const FirebaseOptions ios = FirebaseOptions(
	apiKey: 'DEIN_IOS_API_KEY',
	appId: 'DEINE_IOS_APP_ID',
	messagingSenderId: 'DEINE_SENDER_ID',
	projectId: 'DEIN_PROJECT_ID',
	storageBucket: 'DEIN_PROJECT_ID.appspot.com',
	iosBundleId: 'net.timm-sander.sws',
  );
}
