# ============================================================
# Solar WiFi Weather Station – API Verzeichnisschutz
# ============================================================

# Verzeichnislisting deaktivieren
Options -Indexes

# auth.php und db.php vor Direktzugriff schützen
<FilesMatch "^(auth|db)\.php$">
	Require all denied
</FilesMatch>

# Service-Account-JSON vor Direktzugriff schützen
<FilesMatch "swsfb-11c77-firebase-adminsdk-fbsvc-7dc4d2384c\.json$">
	Require all denied
</FilesMatch>

